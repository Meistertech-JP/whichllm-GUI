<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="whichllm GUI" Height="760" Width="1180" MinHeight="620" MinWidth="980"
        Background="#F6F7F9">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,3,12,8"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="MinWidth" Value="96"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,3,12,8"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="MinWidth" Value="132"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,3,8,8"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="MinWidth" Value="96"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Background="#1F2937" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="whichllm GUI" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,0,16,0"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#D1D5DB"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding IsBusy, StringFormat=Busy: {0}}" Foreground="#D1D5DB"/>
            </Grid>
        </Border>

        <TabControl Margin="12">
            <TabItem Header="おすすめ">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="150"/>
                    </Grid.RowDefinitions>

                    <Border Background="White" BorderBrush="#D8DEE9" BorderThickness="1" CornerRadius="4" Padding="12">
                        <WrapPanel>
                            <StackPanel>
                                <TextBlock Text="件数"/>
                                <TextBox Text="{Binding TopText, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="コンテキスト"/>
                                <TextBox Text="{Binding ContextText, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="用途"/>
                                <ComboBox ItemsSource="{Binding UseCases}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding SelectedUseCase}" Width="150"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="プロファイル"/>
                                <ComboBox ItemsSource="{Binding Profiles}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding SelectedProfile}" Width="150"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="根拠"/>
                                <ComboBox ItemsSource="{Binding EvidenceModes}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding SelectedEvidence}" Width="120"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Fit"/>
                                <ComboBox ItemsSource="{Binding FitModes}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding SelectedFit}" Width="120"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="速度"/>
                                <ComboBox ItemsSource="{Binding SpeedModes}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding SelectedSpeed}" Width="120"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="量子化"/>
                                <TextBox Text="{Binding QuantText, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="GPUシミュレーション"/>
                                <TextBox Text="{Binding SimulatedGpuText, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                            </StackPanel>
                            <CheckBox Content="CPUのみ" IsChecked="{Binding CpuOnly}" Margin="0,24,12,0"/>
                            <CheckBox Content="再取得" IsChecked="{Binding Refresh}" Margin="0,24,12,0"/>
                            <Button Content="推薦を計算" Command="{Binding RunRecommendationCommand}" Margin="8,19,8,8"/>
                            <Button Content="Markdownコピー" Command="{Binding CopyMarkdownCommand}" Margin="0,19,8,8"/>
                            <Button Content="JSONコピー" Command="{Binding CopyJsonCommand}" Margin="0,19,8,8"/>
                        </WrapPanel>
                    </Border>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding RecommendationRows}" SelectedItem="{Binding SelectedResult}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="44"/>
                            <DataGridTextColumn Header="モデル" Binding="{Binding Model}" Width="2*"/>
                            <DataGridTextColumn Header="用途" Binding="{Binding UseCase}" Width="110"/>
                            <DataGridTextColumn Header="Quant" Binding="{Binding Quantization}" Width="100"/>
                            <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="80"/>
                            <DataGridTextColumn Header="Fit" Binding="{Binding Fit}" Width="120"/>
                            <DataGridTextColumn Header="Memory" Binding="{Binding Memory}" Width="110"/>
                            <DataGridTextColumn Header="Speed" Binding="{Binding Speed}" Width="110"/>
                            <DataGridTextColumn Header="Evidence" Binding="{Binding Evidence}" Width="110"/>
                            <DataGridTextColumn Header="Published" Binding="{Binding Published}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBox Grid.Row="2" Text="{Binding SelectedDetails, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/>
                </Grid>
            </TabItem>

            <TabItem Header="ハードウェア">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="150"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="検出" Command="{Binding DetectHardwareCommand}"/>
                        <TextBlock Text="VRAM上書き(GB)" Margin="8,0,4,0"/>
                        <TextBox Text="{Binding VramOverrideText, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                        <TextBlock Text="帯域(GB/s)" Margin="8,0,4,0"/>
                        <TextBox Text="{Binding BandwidthOverrideText, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                        <TextBlock Text="VRAM予約" Margin="8,0,4,0"/>
                        <TextBox Text="{Binding VramHeadroomText, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                        <TextBlock Text="RAM予算" Margin="8,0,4,0"/>
                        <TextBox Text="{Binding RamBudgetText, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding HardwareRows}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="GPU" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="Vendor" Binding="{Binding Vendor}" Width="110"/>
                            <DataGridTextColumn Header="VRAM" Binding="{Binding Vram}" Width="120"/>
                            <DataGridTextColumn Header="Usable" Binding="{Binding UsableVram}" Width="120"/>
                            <DataGridTextColumn Header="Bandwidth" Binding="{Binding Bandwidth}" Width="120"/>
                            <DataGridTextColumn Header="Shared" Binding="{Binding SharedMemory}" Width="90"/>
                            <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBox Grid.Row="2" Text="{Binding HardwareSummary}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/>
                </Grid>
            </TabItem>

            <TabItem Header="導入計画">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <WrapPanel>
                        <StackPanel>
                            <TextBlock Text="モデル検索"/>
                            <TextBox Text="{Binding PlanQuery, UpdateSourceTrigger=PropertyChanged}" Width="260"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Quant"/>
                            <TextBox Text="{Binding PlanQuant, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Context"/>
                            <TextBox Text="{Binding PlanContextText, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                        </StackPanel>
                        <Button Content="計画を作成" Command="{Binding RunPlanCommand}" Margin="8,19,8,8"/>
                        <TextBlock Text="{Binding PlanSummary}" Margin="8,0,0,0"/>
                    </WrapPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding PlanRows}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Quant" Binding="{Binding Quantization}" Width="120"/>
                            <DataGridTextColumn Header="Required" Binding="{Binding Required}" Width="140"/>
                            <DataGridTextColumn Header="Current" Binding="{Binding Current}" Width="100"/>
                            <DataGridTextColumn Header="Fits Common GPUs" Binding="{Binding CommonGpus}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="GPU比較">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <WrapPanel>
                        <StackPanel>
                            <TextBlock Text="比較GPU"/>
                            <TextBox Text="{Binding UpgradeTargetsText, UpdateSourceTrigger=PropertyChanged}" Width="420"/>
                        </StackPanel>
                        <Button Content="比較" Command="{Binding RunUpgradeCommand}" Margin="8,19,8,8"/>
                        <TextBlock Text="{Binding UpgradeSummary}" Margin="8,0,0,0"/>
                    </WrapPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding UpgradeRows}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="GPU" Binding="{Binding TargetGpu}" Width="160"/>
                            <DataGridTextColumn Header="Top Model" Binding="{Binding TopModel}" Width="2*"/>
                            <DataGridTextColumn Header="Score" Binding="{Binding TopScore}" Width="90"/>
                            <DataGridTextColumn Header="Fit" Binding="{Binding Fit}" Width="120"/>
                            <DataGridTextColumn Header="Speed" Binding="{Binding Speed}" Width="120"/>
                            <DataGridTextColumn Header="Gain" Binding="{Binding Gain}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="スニペット">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <WrapPanel>
                        <StackPanel>
                            <TextBlock Text="モデル検索"/>
                            <TextBox Text="{Binding SnippetQuery, UpdateSourceTrigger=PropertyChanged}" Width="280"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Quant"/>
                            <TextBox Text="{Binding SnippetQuant, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                        </StackPanel>
                        <Button Content="生成" Command="{Binding GenerateSnippetCommand}" Margin="8,19,8,8"/>
                        <Button Content="コピー" Command="{Binding CopySnippetCommand}" Margin="0,19,8,8"/>
                    </WrapPanel>
                    <TextBox Grid.Row="1" Text="{Binding SnippetCommandLine}" IsReadOnly="True" FontFamily="Consolas"/>
                    <TextBox Grid.Row="2" Text="{Binding SnippetCode}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/>
                </Grid>
            </TabItem>

            <TabItem Header="設定">
                <Grid Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="キャッシュ" FontWeight="SemiBold" Margin="0,0,12,10"/>
                    <TextBox Grid.Column="1" Text="{Binding CachePath, Mode=OneWay}" IsReadOnly="True"/>
                    <TextBlock Grid.Row="1" Text="HF_ENDPOINT" FontWeight="SemiBold" Margin="0,0,12,10"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding HfEndpoint, Mode=OneWay}" IsReadOnly="True"/>
                    <TextBlock Grid.Row="2" Grid.ColumnSpan="2" TextWrapping="Wrap" Margin="0,12,0,0"
                               Text="runはv1非対応です。推薦、ハードウェア検出、導入計画、GPU比較、Pythonスニペット生成に対応しています。用途フィルタはllmfitのGeneral/Coding/Reasoning/Chat/Multimodal/Embedding思想をGUI向けに取り込み、whichllm由来のprofileとは別に再ランキングへ反映します。"/>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
