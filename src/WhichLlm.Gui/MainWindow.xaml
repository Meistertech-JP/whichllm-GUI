<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:inf="clr-namespace:WhichLlm.Gui.Infrastructure"
        mc:Ignorable="d"
        Title="{Binding AppTitle}" Height="860" Width="1220" MinHeight="720" MinWidth="1040"
        FontFamily="Segoe UI" Background="#F5F5F7">
    <Window.Resources>
        <SolidColorBrush x:Key="Ink" Color="#1D1D1F"/>
        <SolidColorBrush x:Key="Muted" Color="#6E6E73"/>
        <SolidColorBrush x:Key="Line" Color="#D2D2D7"/>
        <SolidColorBrush x:Key="Surface" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Accent" Color="#0071E3"/>

        <inf:FitKindBrushConverter x:Key="FitBrush"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="FocusVisual">
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Rectangle Margin="-3" RadiusX="6" RadiusY="6" StrokeThickness="2" Stroke="{StaticResource Accent}" SnapsToDevicePixels="True"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="Caption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#565659"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#3A3A3C"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="250"/>
            <Setter Property="ToolTipService.ShowDuration" Value="20000"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,12,10"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,12,10"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="MinWidth" Value="132"/>
            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="250"/>
            <Setter Property="ToolTipService.ShowDuration" Value="20000"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,20,16,10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="250"/>
            <Setter Property="ToolTipService.ShowDuration" Value="20000"/>
        </Style>

        <Style TargetType="Expander">
            <EventSetter Event="Expanded" Handler="LocalizedContent_Expanded"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="Margin" Value="0,12,0,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="RowBackground" Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFC"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#ECECF0"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#FBFBFD" BorderBrush="#E5E5EA" BorderThickness="0,0,0,1" Padding="22,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="whichllm" FontSize="24" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding AppVersion}" Style="{StaticResource Caption}" Margin="10,6,0,0"/>
                    </StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource Caption}" Margin="0,3,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="8" Padding="12,6" VerticalAlignment="Center">
                    <TextBlock Text="{Binding IsBusyLabel}" Foreground="#1D4ED8" FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="18,12,18,18" SelectionChanged="MainTabs_SelectionChanged">
            <TabItem Header="おすすめ">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="240"/>
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="このPCに合うモデル" FontSize="22" FontWeight="SemiBold"/>
                                <TextBlock Text="用途を選ぶだけで、動きやすさと根拠を合わせて並べます。" Style="{StaticResource Caption}" Margin="0,6,0,0"/>
                                <TextBlock Text="{Binding RecommendationHardwareSummary}" Style="{StaticResource Caption}" Margin="0,8,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="おすすめを探す" Command="{Binding RunRecommendationCommand}" IsDefault="True" Style="{StaticResource PrimaryButton}" ToolTip="表示中のCPU、RAM、GPU、VRAMを前提に、このPCに合うモデルを探します。"/>
                                <Border BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="6" Background="#FFFFFF" Margin="0,0,10,10" VerticalAlignment="Center">
                                    <Menu Background="Transparent" Padding="0">
                                        <MenuItem Padding="14,7" FontWeight="SemiBold" ToolTip="表示中のおすすめを、ほかのアプリに貼り付けられる形でコピーします。">
                                            <MenuItem.Header>
                                                <TextBlock Text="この結果をコピー  ▾"/>
                                            </MenuItem.Header>
                                            <MenuItem Header="一覧表としてコピー" Command="{Binding CopyMarkdownCommand}" ToolTip="見やすい表の形でコピーします。メールやメモにそのまま貼れます。"/>
                                            <MenuItem Header="データ（JSON）としてコピー" Command="{Binding CopyJsonCommand}" ToolTip="プログラムで扱えるJSON形式でコピーします。"/>
                                        </MenuItem>
                                    </Menu>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Expander Grid.Row="1" Header="詳細条件" Margin="0,12,0,0" IsExpanded="False">
                        <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="14">
                            <WrapPanel>
                                <StackPanel>
                                    <TextBlock Text="表示件数" Style="{StaticResource FieldLabel}" ToolTip="一覧に出す候補数です。迷う場合は10のままで大丈夫です。"/>
                                    <TextBox Text="{Binding TopText, UpdateSourceTrigger=PropertyChanged}" Width="86"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="文脈の長さ" Style="{StaticResource FieldLabel}" ToolTip="一度に扱える文章量です。4096は軽め、長い文章を扱うなら8192以上が目安です。"/>
                                    <TextBox Text="{Binding ContextText, UpdateSourceTrigger=PropertyChanged}" Width="118"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="用途" Style="{StaticResource FieldLabel}" ToolTip="モデルを何に使いたいかです。ランキングの重みと絞り込みに使います。"/>
                                    <ComboBox ItemsSource="{Binding UseCases}" DisplayMemberPath="Label" SelectedItem="{Binding SelectedUseCaseOption, Mode=TwoWay}" Width="188"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="根拠" Style="{StaticResource FieldLabel}" ToolTip="直接ベンチマークだけに絞るか、近いモデルの推定や根拠なし候補も含めるかを選びます。"/>
                                    <ComboBox ItemsSource="{Binding EvidenceModes}" DisplayMemberPath="Label" SelectedItem="{Binding SelectedEvidenceOption, Mode=TwoWay}" Width="220"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="快適度の条件" Style="{StaticResource FieldLabel}" ToolTip="CPUのみも含めるか、GPUからあふれてもOKにするか、GPUメモリ内に収まる候補だけにするかを選びます。"/>
                                    <ComboBox ItemsSource="{Binding FitModes}" DisplayMemberPath="Label" SelectedItem="{Binding SelectedFitOption, Mode=TwoWay}" Width="230"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="速度の条件" Style="{StaticResource FieldLabel}" ToolTip="tok/sは1秒あたりに生成できるトークン数です。10以上なら普段使い、30以上ならかなり速めの目安です。"/>
                                    <ComboBox ItemsSource="{Binding SpeedModes}" DisplayMemberPath="Label" SelectedItem="{Binding SelectedSpeedOption, Mode=TwoWay}" Width="230"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="量子化" Style="{StaticResource FieldLabel}" ToolTip="Q4_K_Mなどの圧縮形式です。空欄ならおすすめの形式を自動で見ます。"/>
                                    <ComboBox IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" ItemsSource="{Binding QuantOptions}" Text="{Binding QuantText, UpdateSourceTrigger=PropertyChanged}" SelectionChanged="EditableSuggestionComboBox_SelectionChanged" Width="150"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="GPUを試算" Style="{StaticResource FieldLabel}" ToolTip="別のGPUを買った場合などを試す入力です。例: RTX 4070, 2x RTX 4090"/>
                                    <ComboBox IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" ItemsSource="{Binding GpuOptions}" Text="{Binding SimulatedGpuText, UpdateSourceTrigger=PropertyChanged}" SelectionChanged="EditableSuggestionComboBox_SelectionChanged" Width="240"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="対象GPU / グループ" Style="{StaticResource FieldLabel}" ToolTip="複数GPU環境で、見積もりの対象を選びます。「まとめて使う」は同世代GPUを全合算、「×k台（合算）」は同一GPUのうちk台だけを合算（例: 3台中2台）、「GPU○ のみ」は特定の1台だけを対象にします。混在世代のGPUは自動合算しません。"/>
                                    <ComboBox ItemsSource="{Binding GpuGroupOptions}" DisplayMemberPath="Label" SelectedItem="{Binding SelectedGpuGroupOption, Mode=TwoWay}" Width="300"/>
                                </StackPanel>
                                <CheckBox Content="CPUのみ" IsChecked="{Binding CpuOnly}" ToolTip="GPUを使わない前提で候補を探します。"/>
                                <CheckBox Content="再取得" IsChecked="{Binding Refresh}" ToolTip="保存済みデータを使わず、モデル情報を取り直します。"/>
                            </WrapPanel>
                        </Border>
                    </Expander>

                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="430"/>
                            <ColumnDefinition Width="400"/>
                        </Grid.ColumnDefinitions>

                        <DataGrid Grid.Column="0" ItemsSource="{Binding RecommendationRows}" SelectedItem="{Binding SelectedResult}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding RankLabel}" Width="124">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="おすすめ" ToolTip="総合おすすめ順の順位です。最有力がいちばんのおすすめです。"/>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding ModelName}" Width="*">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="モデル" ToolTip="モデルの名前です。"/>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding UseCaseLabel}" Width="110">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="用途" ToolTip="この候補が得意とする用途です。"/>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Width="124" SortMemberPath="FitLabel">
                                    <DataGridTemplateColumn.Header>
                                        <TextBlock Text="快適度" ToolTip="このPCでどれくらい無理なく動くかの目安です。緑=快適、橙=動くが重め、灰=要確認。"/>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="9,2" Margin="0,2" HorizontalAlignment="Left"
                                                    Background="{Binding FitKind, Converter={StaticResource FitBrush}, ConverterParameter=bg}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center"
                                                             Fill="{Binding FitKind, Converter={StaticResource FitBrush}, ConverterParameter=dot}"/>
                                                    <TextBlock Text="{Binding FitLabel}" FontWeight="SemiBold"
                                                               Foreground="{Binding FitKind, Converter={StaticResource FitBrush}, ConverterParameter=fg}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Binding="{Binding SpeedWord}" Width="116" SortMemberPath="Speed">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="速度の目安" ToolTip="返事の速さの目安です。詳しい数値は右の詳細に出ます。"/>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Grid.Column="0" Visibility="{Binding ShowEmptyHint, Converter={StaticResource BoolToVis}}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"
                                   MaxWidth="440" Foreground="{StaticResource Muted}" FontSize="14"
                                   Text="「おすすめを探す」を押すと、このPCで使えるモデルが一覧で出ます。"/>

                        <Border Grid.Column="1" Margin="12,0,0,0" Padding="16,14"
                                Background="{StaticResource Surface}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="12"
                                Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel DataContext="{Binding SelectedResult}">
                                    <Border Background="#E6F1FB" CornerRadius="10" Padding="9,2" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding RankLabel}" Foreground="#0C447C" FontWeight="SemiBold" FontSize="12"/>
                                    </Border>
                                    <TextBlock Text="{Binding ModelName}" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding UseCaseLabel}" Style="{StaticResource Caption}" Margin="0,2,0,0"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Border CornerRadius="10" Padding="10,3" Background="{Binding FitKind, Converter={StaticResource FitBrush}, ConverterParameter=bg}">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="9" Height="9" Margin="0,0,6,0" VerticalAlignment="Center" Fill="{Binding FitKind, Converter={StaticResource FitBrush}, ConverterParameter=dot}"/>
                                                <TextBlock Text="{Binding FitLabel}" FontWeight="SemiBold" Foreground="{Binding FitKind, Converter={StaticResource FitBrush}, ConverterParameter=fg}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border CornerRadius="10" Padding="10,3" Margin="8,0,0,0" Background="#EFEFF0">
                                            <TextBlock Text="{Binding SpeedWord}" FontWeight="SemiBold" Foreground="#3A3A3C"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBox Text="{Binding WhyLine}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" BorderThickness="0"
                                             Background="Transparent" Foreground="#565659" FontSize="13" Padding="0"
                                             Margin="0,10,0,0" MinHeight="42" VerticalScrollBarVisibility="Disabled"/>
                                    <Border BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Margin="0,12,0,12"/>
                                    <TextBox Text="{Binding Details}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Disabled" BorderThickness="0" Background="Transparent" FontFamily="Meiryo UI" Padding="0"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="このPC">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="148"/>
                    </Grid.RowDefinitions>
                    <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="このPCの余力" FontSize="22" FontWeight="SemiBold"/>
                                <TextBlock Text="GPU、メモリ、CPUを確認して、推薦の前提に使います。" Style="{StaticResource Caption}" Margin="0,6,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="再検出" Command="{Binding DetectHardwareCommand}" Style="{StaticResource PrimaryButton}" ToolTip="CPU、メモリ、GPUをもう一度読み取ります。"/>
                        </Grid>
                    </Border>

                    <Expander Grid.Row="1" Header="手入力で調整" Margin="0,12,0,0" IsExpanded="False">
                        <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="14">
                            <WrapPanel>
                                <StackPanel>
                                    <TextBlock Text="GPUメモリ上書き(GB)" Style="{StaticResource FieldLabel}" ToolTip="自動検出が違う時に、GPUメモリをGB単位で指定します。"/>
                                    <TextBox Text="{Binding VramOverrideText, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="帯域(GB/s)" Style="{StaticResource FieldLabel}" ToolTip="GPUメモリの速さです。分かる場合だけ入力します。"/>
                                    <TextBox Text="{Binding BandwidthOverrideText, UpdateSourceTrigger=PropertyChanged}" Width="126"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="GPUメモリ予約" Style="{StaticResource FieldLabel}" ToolTip="OSや他のアプリのために空けておくGPUメモリです。autoで安全寄りに計算します。"/>
                                    <TextBox Text="{Binding VramHeadroomText, UpdateSourceTrigger=PropertyChanged}" Width="126"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="メインメモリ予算" Style="{StaticResource FieldLabel}" ToolTip="CPUや一部オフロードで使ってよいメモリ量です。availableで現在の空きメモリを使います。"/>
                                    <TextBox Text="{Binding RamBudgetText, UpdateSourceTrigger=PropertyChanged}" Width="138"/>
                                </StackPanel>
                            </WrapPanel>
                        </Border>
                    </Expander>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding HardwareRows}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="グラフィック" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="メーカー" Binding="{Binding Vendor}" Width="108"/>
                            <DataGridTextColumn Binding="{Binding Vram}" Width="120">
                                <DataGridTextColumn.Header><TextBlock Text="専用メモリ" ToolTip="GPU専用のメモリ量（VRAM）です。モデルがここに収まるほど快適に動きます。"/></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding UsableVram}" Width="122">
                                <DataGridTextColumn.Header><TextBlock Text="使える目安" ToolTip="OSなどの使用分を差し引いた、実際にモデルに使えるメモリの目安です。"/></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding Bandwidth}" Width="120">
                                <DataGridTextColumn.Header><TextBlock Text="メモリ速度" ToolTip="GPUメモリの速さ（GB/s）です。大きいほど生成が速くなりやすいです。"/></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding SharedMemory}" Width="92">
                                <DataGridTextColumn.Header><TextBlock Text="種類" ToolTip="「専用」はGPU独自のメモリ、「共有」はメインメモリと共用するタイプです。"/></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="メモ" Binding="{Binding Notes}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Grid.Row="3" Background="{StaticResource Surface}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,12,0,0">
                        <TextBox Text="{Binding HardwareSummary}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" BorderThickness="0" Background="Transparent" FontFamily="Meiryo UI"/>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="プラン">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="動かす前のプラン" FontSize="22" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding PlanSummary}" Style="{StaticResource Caption}" Margin="0,6,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="プランを作成" Command="{Binding RunPlanCommand}" Style="{StaticResource PrimaryButton}" ToolTip="指定したモデルについて、量子化ごとの必要メモリを見積もります。"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="{StaticResource Surface}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,12,0,0">
                        <WrapPanel>
                            <StackPanel>
                                <TextBlock Text="モデル名" Style="{StaticResource FieldLabel}" ToolTip="探したいモデル名の一部です。例: llama 3 8b"/>
                                <ComboBox IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" ItemsSource="{Binding PlanModelOptions}" Text="{Binding PlanQuery, UpdateSourceTrigger=PropertyChanged}" SelectionChanged="EditableSuggestionComboBox_SelectionChanged" Width="320"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="量子化" Style="{StaticResource FieldLabel}" ToolTip="Q4_K_Mなどの形式です。空欄なら代表的な形式をまとめて見積もります。"/>
                                <ComboBox IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" ItemsSource="{Binding PlanQuantOptions}" Text="{Binding PlanQuant, UpdateSourceTrigger=PropertyChanged}" SelectionChanged="EditableSuggestionComboBox_SelectionChanged" Width="150"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="文脈の長さ" Style="{StaticResource FieldLabel}" ToolTip="長い文章を扱うほど必要メモリが増えます。"/>
                                <TextBox Text="{Binding PlanContextText, UpdateSourceTrigger=PropertyChanged}" Width="126"/>
                            </StackPanel>
                        </WrapPanel>
                    </Border>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding PlanRows}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="量子化" Binding="{Binding Quantization}" Width="126"/>
                            <DataGridTextColumn Header="必要メモリ" Binding="{Binding Required}" Width="140"/>
                            <DataGridTextColumn Header="このPC" Binding="{Binding Current}" Width="150"/>
                            <DataGridTextColumn Header="合いやすいGPU" Binding="{Binding CommonGpus}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="買い替え比較">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="GPUを替えたらどう変わるか" FontSize="22" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding UpgradeSummary}" Style="{StaticResource Caption}" Margin="0,6,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="比較" Command="{Binding RunUpgradeCommand}" Style="{StaticResource PrimaryButton}" ToolTip="候補GPUごとに、最有力モデルと伸び幅を比べます。"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="{StaticResource Surface}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="比較するGPU" Style="{StaticResource FieldLabel}" ToolTip="カンマ区切りで複数入力できます。例: RTX 4070, RX 7900 XTX"/>
                            <ComboBox IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" ItemsSource="{Binding UpgradeGpuOptions}" Text="{Binding UpgradeTargetsText, UpdateSourceTrigger=PropertyChanged}" SelectionChanged="EditableSuggestionComboBox_SelectionChanged" Width="560"/>
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding UpgradeRows}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="GPU" Binding="{Binding TargetGpu}" Width="170"/>
                            <DataGridTextColumn Header="最有力モデル" Binding="{Binding TopModel}" Width="2*"/>
                            <DataGridTextColumn Header="スコア" Binding="{Binding TopScore}" Width="90"/>
                            <DataGridTextColumn Header="快適度" Binding="{Binding Fit}" Width="120"/>
                            <DataGridTextColumn Header="速度目安" Binding="{Binding Speed}" Width="120"/>
                            <DataGridTextColumn Header="伸び幅" Binding="{Binding Gain}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="スニペット">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="開発者向けスニペット" FontSize="22" FontWeight="SemiBold"/>
                                <TextBlock Text="モデルを動かすためのPythonコードとuvコマンドを作ります。" Style="{StaticResource Caption}" Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="生成" Command="{Binding GenerateSnippetCommand}" Style="{StaticResource PrimaryButton}" ToolTip="指定したモデルと量子化でコードを生成します。"/>
                                <Button Content="コピー" Command="{Binding CopySnippetCommand}" Style="{StaticResource SecondaryButton}" ToolTip="コマンドとコードをまとめてコピーします。"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Grid.Row="1" Background="{StaticResource Surface}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,12,0,0">
                        <WrapPanel>
                            <StackPanel>
                                <TextBlock Text="モデル名" Style="{StaticResource FieldLabel}" ToolTip="探したいモデル名の一部です。例: qwen 7b"/>
                                <ComboBox IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" ItemsSource="{Binding SnippetModelOptions}" Text="{Binding SnippetQuery, UpdateSourceTrigger=PropertyChanged}" SelectionChanged="EditableSuggestionComboBox_SelectionChanged" Width="320"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="量子化" Style="{StaticResource FieldLabel}" ToolTip="GGUFの量子化形式です。例: Q4_K_M"/>
                                <ComboBox IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" ItemsSource="{Binding SnippetQuantOptions}" Text="{Binding SnippetQuant, UpdateSourceTrigger=PropertyChanged}" SelectionChanged="EditableSuggestionComboBox_SelectionChanged" Width="150"/>
                            </StackPanel>
                        </WrapPanel>
                    </Border>
                    <TextBox Grid.Row="2" Text="{Binding SnippetCommandLine}" IsReadOnly="True" FontFamily="Consolas" Margin="0,12,0,10"/>
                    <TextBox Grid.Row="3" Text="{Binding SnippetCode}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/>
                </Grid>
            </TabItem>

            <TabItem Header="設定">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="18">
                        <TextBlock Text="設定" FontSize="22" FontWeight="SemiBold"/>
                    </Border>
                    <Border Grid.Row="1" Background="{StaticResource Surface}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,12,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="データの保存場所" Style="{StaticResource FieldLabel}" ToolTip="取得したモデル情報とベンチマーク情報を保存する場所です。"/>
                            <TextBox Grid.Column="1" Text="{Binding CachePath, Mode=OneWay}" IsReadOnly="True"/>
                            <TextBlock Grid.Row="1" Text="接続先（通常は変更不要）" Style="{StaticResource FieldLabel}" ToolTip="モデル情報の取得先（HF_ENDPOINT）です。通常はこのままで使います。"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding HfEndpoint, Mode=OneWay}" IsReadOnly="True"/>
                            <TextBlock Grid.Row="2" Text="表示言語" Style="{StaticResource FieldLabel}" ToolTip="画面に表示する言語です。"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding LanguageOptions}" DisplayMemberPath="Label" SelectedItem="{Binding SelectedLanguageOption, Mode=TwoWay}" Width="180" HorizontalAlignment="Left"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
